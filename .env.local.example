# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=run: openssl rand -base64 32

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Ollama VPS
OLLAMA_BASE_URL=http://your-vps-ip:11434
OLLAMA_MODEL_FREE=qwen3.5:9b
OLLAMA_MODEL_PRO=qwen3.6:27b

# Upstash Redis (BullMQ)
UPSTASH_REDIS_REST_URL=https://your-upstash.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ioredis direct connection (local dev / self-hosted Redis)
REDIS_URL=redis://localhost:6379

# Worker concurrency (set on VPS)
OLLAMA_CONCURRENCY=2
